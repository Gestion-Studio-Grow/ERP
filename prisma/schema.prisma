// Prisma schema — Estetica ERP (Fase 1 del blueprint "Servicios", ADR-010)
// Multi-tenant a nivel de datos (ADR-001 / G1): toda tabla de negocio lleva
// `tenantId`. Hoy hay un solo tenant (Beauty & Spa); el aislamiento es a nivel
// de aplicación vía src/lib/tenant.ts. RLS de Postgres se activa con el 2º
// tenant (ver nota en el modelo Tenant).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentMethod {
  MERCADOPAGO
  EFECTIVO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

// Tipo de mensaje que arma el panel de recordatorios (ADR-012). Cada tipo
// tiene su propia plantilla editable por tenant; el canal (email/whatsapp)
// es un atributo de la plantilla, no del tipo, porque el mismo aviso puede
// mandarse por ambos canales con textos distintos.
enum MessageTemplateType {
  APPOINTMENT_REMINDER
  PROFESSIONAL_NEWS_BROADCAST
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

// Estado de un anotado en la lista de espera. WAITING = esperando un hueco;
// NOTIFIED = recepción ya le avisó que se liberó algo (aún sin reservar);
// BOOKED = se convirtió en turno real (queda el histórico + bookedAppointmentId);
// CANCELLED = se dio de baja (ya no quiere o se resolvió por otro lado).
enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  CANCELLED
}

// Rol de un usuario del panel (ADR-017 §2.b / ADR-009 §3). Enum fijo de 3, sin
// editor granular a propósito: negocios chicos quieren roles con nombres que
// entienden, no una matriz de permisos. OWNER absorbe el "admin" de hoy.
enum UserRole {
  OWNER
  RECEPTION
  PROFESSIONAL
}

// --- Capability POS / Orden (ADR-003 "Orden/Venta" + Fase 2 POS) ---
// Enums del Core, no del blueprint carnicería: los reusa cualquier vertical
// retail (kiosco, autoservicio), por eso viven en el Core (blueprint-carniceria
// -brief §6, decisión 2).

// Cómo se vende un producto. UNIT = por unidad (default, no rompe el spa).
// WEIGHT = por peso/kg (corte de carnicería) — el diferencial #1 vs Bistrosoft.
enum ProductSaleUnit {
  UNIT
  WEIGHT
}

// Ciclo de vida de un pedido/venta. Un pedido de mostrador nace CONFIRMED
// (venta inmediata); uno de la vidriera online nace PENDING (falta que el
// mostrador lo confirme). READY = listo para retiro/despacho.
enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

// Canal de origen del pedido.
enum OrderChannel {
  COUNTER // mostrador (POS presencial)
  ONLINE // vidriera / toma de pedido online
}

// Cómo se entrega el pedido.
enum FulfillmentType {
  PICKUP // retira en el local
  DELIVERY // envío a domicilio
}

// --- Capability CAJA del POS (turno de mostrador / arqueo) ---
// Cierra el agujero del vertical retail: apertura/cierre de turno, movimientos de
// dinero y arqueo (esperado vs contado). Enums del Core: los reusa cualquier
// vertical que cobre en efectivo por mostrador (carnicería, kiosco, spa).

// Estado del turno de caja. ABIERTA = hay un turno operando (acepta movimientos);
// CERRADA = arqueada y cerrada (histórico inmutable). A lo sumo UNA ABIERTA por
// tenant a la vez — lo garantiza la lógica de dominio, no un unique parcial (el
// schema no lo expresa sin índice parcial, y con un solo mostrador alcanza).
enum CashSessionStatus {
  OPEN
  CLOSED
}

// Tipo de movimiento de caja. APERTURA = fondo inicial declarado al abrir el
// turno (una sola fila por sesión). VENTA = ingreso por una venta en efectivo
// (referencia opcional a Order). INGRESO/EGRESO = entrada/salida de dinero por
// otro motivo (pago a proveedor, cambio, etc.). RETIRO = extracción de efectivo
// del cajón (a la caja fuerte / al dueño). El signo aritmético lo decide la
// lógica de arqueo (src/lib/caja), no el enum, para que el monto siempre sea
// positivo y auditable.
enum CashMovementType {
  APERTURA
  VENTA
  INGRESO
  EGRESO
  RETIRO
}

// Tenant (negocio) — raíz del aislamiento multi-tenant (ADR-001). Cada tabla de
// negocio referencia un tenant. Por ahora hay uno solo (Beauty & Spa); el
// modelo nace preparado para muchos sin rediseñar. La zona horaria vive acá
// (AMD-004: config del tenant, no del servidor).
// NOTA (ADR-010 G1): la mitad de RLS de ADR-001 (ENABLE ROW LEVEL SECURITY +
// contexto de tenant por transacción) se difiere hasta el 2º tenant — con uno
// solo, y con la resolución de tenant fail-closed (ADR-015: getCurrentTenantId()
// lanza error si hay ≠1 tenant), no hay leak cross-tenant posible; RLS+pooling es
// el punto más riesgoso de tocar sin necesidad.
// El aislamiento hoy es a nivel de aplicación (tenantId en cada create/read).
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("America/Argentina/Buenos_Aires")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boxes           Box[]
  boxBlocks       BoxBlock[]
  professionals   Professional[]
  workingHours    WorkingHours[]
  services        Service[]
  products        Product[]
  serviceProducts ServiceProduct[]
  clients         Client[]
  appointments    Appointment[]
  reviews         Review[]
  payments        Payment[]
  auditLogs       AuditLog[]
  serviceCategories ServiceCategory[]
  professionalBlocks ProfessionalBlock[]
  serviceCommissions ProfessionalServiceCommission[]
  resources          Resource[]
  serviceResources   ServiceResource[]
  messageTemplates   MessageTemplate[]
  professionalNews   ProfessionalNews[]
  coupons            Coupon[]
  users              User[]
  businessSettings   BusinessSettings?
  commissionPayouts  CommissionPayout[]
  waitlistEntries    WaitlistEntry[]
  invoices           Invoice[]
  outboxEvents       OutboxEvent[]
  orders             Order[]
  orderItems         OrderItem[]
  cashSessions       CashSession[]
  cashMovements      CashMovement[]
  stockPurchases     StockPurchase[]
  stockPurchaseItems StockPurchaseItem[]
  stockMovements     StockMovement[]
  suppliers          Supplier[] // D1 — proveedor maestro (ADR-060 Fase C)
  collections        Collection[] // D9 — cobros/settlement (ADR-060 Fase C.5)
  accountsPayable    AccountPayable[] // D2 — cuentas a pagar (ADR-060 Fase D)
  payableCheques     PayableCheque[] // D2 — cheques diferidos
  accountsReceivable AccountReceivable[] // D3 — fiado / cuentas a cobrar (ADR-060 Fase E)
  importacionesBancarias   ImportacionBancaria[] // módulo BANCOS — extractos importados
  movimientosImportados    MovimientoImportado[] // módulo BANCOS — movimientos del extracto
  reglasClasificacionBanco ReglaClasificacionBancoTenant[] // módulo BANCOS — aprendizaje del clasificador
  carteraClientes          CarteraCliente[]                @relation("CarteraDelEstudio") // módulo CARTERA — clientes que administra este estudio
  carteraComoCliente       CarteraCliente[]                @relation("CarteraComoCliente") // módulo CARTERA — carteras donde este tenant es el cliente

  // --- Control-plane / operador (ADR-021): metadata de PLATAFORMA por tenant ---
  // La gestiona el plano de operador (superficie separada, cross-tenant), no el
  // backoffice del tenant. Todo aditivo/nullable: los tenants existentes siguen
  // válidos sin backfill. La migración que agrega estas columnas queda ESCRITA y
  // SIN aplicar a Neon (Gate 2).
  status       TenantStatus @default(TRIAL) // activo / en pruebas / suspendido
  plan         String? // id de plan comercial (free-form; planes reales → ADR-006)
  blueprintId  String? // vertical sembrado en el alta (servicios/carniceria/generico)
  subdomain    String?      @unique // link/routing propio del tenant (cada uno su URL)
  modules      String[]     @default([]) // módulos/pantallas activos por tenant
  accentPreset String? // preset de acento del branding (src/lib/branding.ts)
  frontTheme   String? // "light" | "dark" — tema de la vidriera del tenant

  // --- Perfil GROW-AR (ADR-058/059 D1, PR-2/M2): "Comercio" (lite) ↔ "Empresa" (enterprise) ---
  // Nombres de motor en INGENIERÍA (`lite`/`enterprise`); el cliente ve "Comercio"/"Empresa"
  // (ADR-059 D7, naming al cliente — nunca lite/enterprise de cara al tenant). Columna ADITIVA
  // con DEFAULT: los tenants existentes quedan en `lite` sin backfill manual ni pérdida de dato.
  // Reemplaza el override en memoria de `getActiveProfile` (`src/lib/profile-gating.ts`) — motor
  // sigue reversible por `PROFILES_ENABLED` (flag OFF = no se lee ni se gatea por esta columna).
  profile TenantProfile @default(lite)

  // --- Config fiscal / ARCA por tenant (ADR-022 §5, CORE-SCHEMA-SPEC opción B) ---
  // SOLO metadata no sensible. El certificado X.509 + clave del emisor NO viven en
  // la DB: entran por env/secret store (`ARCA_CERT_PEM`/`ARCA_KEY_PEM`, `credencialDesdeEnv`).
  // `clientePara(tenantId)` (src/lib/arca-dispatch.ts) arma el `EmisorConfig` desde acá.
  // Aditivo/nullable — sin backfill. Migración ESCRITA y SIN aplicar a Neon (Gate 2).
  // `arcaCuit` es String (no Int como sugería el spec): un CUIT de 11 dígitos no entra
  // en Int32 de Postgres — mismo criterio que `Invoice.docNro`.
  arcaCuit         String? // CUIT del emisor (11 dígitos, sin guiones)
  arcaPuntoVenta   Int? // punto de venta habilitado en ARCA
  arcaHomologacion Boolean @default(true) // true = testing ARCA (seguro por default); false = producción

  // --- Config del módulo BANCOS por tenant (mismo patrón que `arca*`: ADR-022 §5 opción B) ---
  // SOLO metadata no sensible. Nulos = defaults del producto (umbral $600.000, cap 159 —
  // ver src/plugins/bancos/domain/reglas.ts, reglas comerciales del dueño). Aditivo/nullable,
  // sin backfill. Migración ESCRITA y SIN aplicar a Neon (Gate 2).
  bancosUmbralIdentificacion Decimal? @db.Decimal(14, 2) // pesos desde los cuales se exige identificar al receptor
  bancosCapFacturasMes       Int? // tope de facturas automáticas por mes
  bancosDomicilioEmisor      String? // domicilio comercial del emisor (obligatorio en el comprobante)
}

// Estado de un tenant en la plataforma (control-plane, ADR-021). TRIAL = en
// pruebas (default del alta), ACTIVE = operando/pagando, SUSPENDED = pausado sin
// borrar datos.
// Perfil GROW-AR del tenant (ADR-058/059): `lite` = "Comercio" (micro, mínimo que resuelve),
// `enterprise` = "Empresa" (pyme, proceso completo). Invariante `enterprise ⊇ lite` (crecé sin
// migrar) lo garantiza `perfilGateAllows`/`resolveNavLockState` (`src/modules/`), no el schema.
enum TenantProfile {
  lite
  enterprise
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

// Configuración de localización y contacto del negocio (módulo Localización).
// Singleton por tenant (un negocio = una ficha; `tenantId` es único). Alimenta el
// bloque público "Dónde estamos / Cómo llegar", el footer y el hero del sitio,
// que antes tenían estos datos hardcodeados en el código y en business-config.ts.
// Todos los campos son opcionales A PROPÓSITO: si están vacíos, el sitio cae a los
// valores por defecto (src/lib/settings.ts), así la web nunca queda rota por falta
// de configuración. Los horarios acá son una LEYENDA pública (texto libre); los
// horarios operativos reales siguen viviendo por profesional en WorkingHours.
model BusinessSettings {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    String   @unique
  shortLabel  String? // "eyebrow" del hero: "La Alameda · Canning"
  addressLine String? // "Barrio La Alameda, Canning"
  city        String? // "Buenos Aires"
  hoursLabel  String? // "Lun a sáb · 9 a 19 h"
  whatsapp    String? // solo dígitos (formato wa.me); reemplaza el número de business-config.ts
  email       String?
  instagram   String? // handle o URL
  mapsUrl     String? // URL de mapa; si es null, se arma desde addressLine + city
  contactNote String? // leyenda de contacto del footer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Usuario del panel admin (ADR-017). Identidad propia, NO se reusa Professional:
// el dueño y la recepción no son profesionales, y no todo profesional tiene login.
// email es el identificador de login, único por tenant. passwordHash con scrypt
// (formato scrypt$<salt>$<hash>, ver src/lib/auth-password.ts). professionalId
// enlaza opcionalmente a un Professional cuando el usuario además opera su agenda.
model User {
  id             String        @id @default(cuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tenantId       String
  name           String
  email          String
  passwordHash   String
  role           UserRole
  active         Boolean       @default(true)
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?       @unique
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

// Categoría de servicios (ADR-011 G16): agrupa el catálogo (Faciales, Masajes,
// Spa, etc.). Ordenable para controlar cómo se muestra en la web y el admin.
model ServiceCategory {
  id       String    @id @default(cuid())
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  tenantId String
  name     String
  order    Int       @default(0)
  services Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, order])
}

model Box {
  id            String         @id @default(cuid())
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  tenantId      String
  name          String
  active        Boolean        @default(true)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  professionals Professional[]
  appointments  Appointment[]
  blocks        BoxBlock[]

  @@index([tenantId])
}

// Bloquea un box durante un rango de fechas (ej. reservado para un servicio
// especial) sin tener que reasignar el box fijo de cada profesional.
model BoxBlock {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  box       Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  boxId     String
  startsAt  DateTime
  endsAt    DateTime
  reason    String
  createdAt DateTime @default(now())

  @@index([boxId, startsAt, endsAt])
  @@index([tenantId])
}

model Professional {
  id                String        @id @default(cuid())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  tenantId          String
  name              String
  email             String?
  phone             String?
  active            Boolean       @default(true)
  box               Box?          @relation(fields: [boxId], references: [id])
  boxId             String?
  commissionPercent Float         @default(0)
  deletedAt         DateTime?
  services          Service[]     @relation("ProfessionalServices")
  appointments      Appointment[]
  reviews           Review[]
  workingHours      WorkingHours[]
  blocks            ProfessionalBlock[]
  serviceCommissions ProfessionalServiceCommission[]
  news              ProfessionalNews[]
  user              User?
  commissionPayouts CommissionPayout[]
  waitlistEntries   WaitlistEntry[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId])
}

// Horario de trabajo de un profesional para un día de la semana
// (0 = domingo ... 6 = sábado). Si un profesional no tiene fila para un
// día, se considera que no trabaja ese día.
model WorkingHours {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  dayOfWeek      Int
  startTime      String // "09:00"
  endTime        String // "19:00"

  @@unique([professionalId, dayOfWeek])
  @@index([tenantId])
}

model Service {
  id            String           @id @default(cuid())
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  tenantId      String
  category      ServiceCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  name          String
  description   String?
  durationMin   Int
  price         Float
  // Precio preferencial para vecinos de La Alameda (ADR-013). Opcional a
  // propósito: no todos los servicios tienen diferencial — si es null, el
  // servicio cobra `price` para todos. Nunca se muestra como "recargo" al
  // resto, siempre como beneficio vecino.
  residentPrice Float?
  // Seña obligatoria (ADR-014): monto fijo que hay que abonar para confirmar
  // el turno. Opcional por servicio, igual que residentPrice — null = no
  // exige seña. El cobro en sí sigue siendo manual (confirmPayment) hasta
  // que se conecte Mercado Pago Checkout; esto solo hace visible la
  // condición al cliente antes de reservar, como ya hace el negocio hoy.
  depositAmount Float?
  active        Boolean          @default(true)
  deletedAt     DateTime?
  professionals Professional[]   @relation("ProfessionalServices")
  appointments  Appointment[]
  products      ServiceProduct[]
  resources     ServiceResource[]
  serviceCommissions ProfessionalServiceCommission[]
  waitlistEntries WaitlistEntry[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Config de recordatorio por servicio (ADR-012 / panel de recordatorios).
  // Si reminderEnabled es false, el job de recordatorios se lo salta aunque
  // el turno esté confirmado. reminderHoursBefore reemplaza la ventana fija
  // de 24hs que tenía el job original.
  reminderEnabled     Boolean @default(true)
  reminderHoursBefore Int     @default(24)

  @@index([tenantId])
  @@index([categoryId])
}

// Insumo de stock (ej. cera, crema, guantes).
model Product {
  id           String           @id @default(cuid())
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  tenantId     String
  name         String
  unit         String           @default("unidades")
  stock        Float            @default(0)
  lowStockAt   Float            @default(5)
  active       Boolean          @default(true)
  deletedAt    DateTime?
  services     ServiceProduct[]

  // --- Extensión "venta al público / retail" (mec. A de ADR-002) ---
  // Campos aditivos, nullable/defaulted: el blueprint Servicios (spa) los ignora
  // y sigue igual; el blueprint Carnicería/Retail los usa para vender cortes por
  // peso. NO hay tabla nueva: es extensión del Producto existente (FUNDAMENTOS §2,
  // blueprint-carniceria-brief §2 y decisión 1).
  saleUnit     ProductSaleUnit  @default(UNIT) // UNIT = por unidad, WEIGHT = por kg
  price        Float? // precio de venta unitario (saleUnit=UNIT). Null = no se vende suelto
  pricePerKg   Float? // precio por kilo (saleUnit=WEIGHT). Diferencial #1 vs Bistrosoft
  // trackStock: si true, vender por POS/vidriera DESCUENTA `stock` con guarda anti-oversell
  // (order-core.ts). Default false → los productos que no controlan existencias (insumos de
  // spa, o retail sin stock cargado) se siguen vendiendo sin bloqueo, como antes. El blueprint
  // Retail lo siembra en true. (POS/stock — 2026-07-05)
  trackStock   Boolean          @default(false)
  orderItems   OrderItem[]
  purchaseItems StockPurchaseItem[] // entradas de stock (compras/reposiciones) que lo repusieron
  stockMovements StockMovement[]   // ledger de movimientos de stock (entradas y salidas)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId])
}

// Cuánto de un producto consume un servicio cada vez que se realiza.
// Al completar un turno se descuenta quantity del stock del producto.
model ServiceProduct {
  id        String  @id @default(cuid())
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  tenantId  String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Float   @default(1)

  @@unique([serviceId, productId])
  @@index([tenantId])
}

model Client {
  id           String        @id @default(cuid())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  tenantId     String
  name         String
  phone        String
  email        String?
  notes        String?
  birthDate    DateTime?
  // Vecino/a de La Alameda (ADR-013): lo responde el cliente al reservar.
  // Null = todavía no se le preguntó (clientes previos a esta feature).
  isResident   Boolean?
  appointments Appointment[]
  orders       Order[]
  receivables  AccountReceivable[] // D3 — fiado de este cliente (ADR-060 Fase E)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
}

model Appointment {
  id             String            @id @default(cuid())
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  tenantId       String
  client         Client            @relation(fields: [clientId], references: [id])
  clientId       String
  professional   Professional      @relation(fields: [professionalId], references: [id])
  professionalId String
  service        Service           @relation(fields: [serviceId], references: [id])
  serviceId      String
  box            Box               @relation(fields: [boxId], references: [id])
  boxId          String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(PENDING)
  // Precio del servicio congelado al momento de reservar (AMD-003): el precio
  // del servicio puede cambiar entre la reserva y el cobro; esto evita la
  // discusión con el cliente. Nullable para los turnos previos a esta feature.
  priceAtBooking Float?
  // Si el precio congelado arriba fue el preferencial de vecino (ADR-013) —
  // separado de Client.isResident porque el cliente puede cambiar de
  // respuesta entre turnos; esto es historial, no estado actual.
  isResidentBooking Boolean @default(false)
  // Cupón aplicado al reservar (ADR-014), si lo hubo — historial, no relación
  // fuerte a Coupon para que el turno no se rompa si el cupón se borra.
  couponCode     String?
  discountAmount Float             @default(0)
  // Nota libre de la recepción (AMD-003): "quiere el mismo tono de la vez pasada".
  notes          String?
  payment        Payment?
  review         Review?
  collections    Collection[] // D9 — cobros (parciales/total) imputados a este turno
  invoices       Invoice[] // D10 — facturas cuyo origen es este turno
  reminderSentAt DateTime?
  // Liquidación de comisiones (BACKLOG "Alta prioridad"). La comisión de un turno
  // se devenga cuando está COMPLETED con pago APPROVED; queda "pendiente de pago"
  // mientras este campo es null. Al liquidar un período, el turno se estampa con
  // el payout que lo cubrió — así "pendiente" = COMPLETED + pago APPROVED +
  // commissionPayoutId null, y volver a liquidar no puede doble-pagar (structural).
  commissionPayout   CommissionPayout? @relation(fields: [commissionPayoutId], references: [id])
  commissionPayoutId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([professionalId, startsAt])
  @@index([boxId, startsAt])
  @@index([tenantId, startsAt])
  @@index([commissionPayoutId])
}

// Liquidación de comisiones a un profesional por un período (BACKLOG "Alta
// prioridad"). Antes las comisiones se calculaban al vuelo en Reportes pero no
// había forma de marcar un período como pagado ni histórico — la dueña no podía
// saber si ya le había pagado a un profesional. Cada payout congela el monto
// liquidado y agrupa los turnos que cubrió (Appointment.commissionPayoutId), de
// modo que el pago es idempotente: los turnos ya estampados salen del pendiente
// y no se pueden liquidar dos veces. periodStart/End son el rango real de turnos
// cubiertos (min/max de startsAt), no un rango elegido a mano, para que el
// comprobante refleje exactamente lo que se pagó.
model CommissionPayout {
  id               String        @id @default(cuid())
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  tenantId         String
  professional     Professional  @relation(fields: [professionalId], references: [id])
  professionalId   String
  amount           Float // comisión total liquidada (congelada)
  appointmentCount Int // cuántos turnos completados cubrió
  periodStart      DateTime // startsAt más temprano cubierto (UTC)
  periodEnd        DateTime // startsAt más tardío cubierto (UTC)
  note             String? // nota libre del comprobante (ej. "pagado por transferencia")
  settledBy        String // actor que liquidó ("user:<id>"), para el audit
  appointments     Appointment[]
  createdAt        DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([professionalId])
}

// Reseña rápida que el cliente puede dejar una vez que el turno se completó.
// "published" la controla el dueño del negocio antes de que se vea en la web.
model Review {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId  String       @unique
  professional   Professional @relation(fields: [professionalId], references: [id])
  professionalId String
  clientName     String
  rating         Int
  comment        String?
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([tenantId])
}

model Payment {
  id              String        @id @default(cuid())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  appointmentId   String        @unique
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  mpPaymentId     String?
  mpPreferenceId  String?
  comprobanteNro  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
}

enum CouponType {
  PERCENT
  FIXED
}

// Cupón de descuento (ADR-014). Se valida y aplica al reservar (createAppointment
// / createBookingFromModal / createManualAppointment), nunca confiando en el
// descuento que calculó el cliente — el server vuelve a calcularlo.
model Coupon {
  id        String     @id @default(cuid())
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  tenantId  String
  code      String
  type      CouponType
  value     Float // % (0-100) si type=PERCENT, monto fijo si type=FIXED
  active    Boolean    @default(true)
  expiresAt DateTime?
  maxUses   Int? // null = sin límite
  usedCount Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

// Registro append-only de mutaciones de negocio (ADR-009 §4). Se puebla desde
// un único helper (src/lib/audit.ts) invocado por la capa de server actions —
// un solo punto de intercepción, no triggers dispersos. Es Fase 1, no Fase 3:
// retrofitearlo después dejaría un agujero histórico permanente.
model AuditLog {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  actor     String // quién: "admin", "cliente:<telefono>", "system"
  action    String // "create" | "update" | "confirm_payment" | "complete" | "cancel" | "no_show" | "delete" | ...
  entity    String // "Appointment" | "Service" | "Box" | "Product" | "Professional" | "Review" | ...
  entityId  String?
  changes   Json? // detalle / diff antes-después
  channel   String? // "admin" | "public"
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([tenantId, createdAt])
}

// Bloqueo de agenda por profesional (ADR-011 G9): franco, vacaciones, o novedad
// puntual en la que el profesional no está. Análogo a BoxBlock pero por persona.
// Recorta la disponibilidad que da WorkingHours para fechas concretas.
model ProfessionalBlock {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  startsAt       DateTime // UTC (AMD-004)
  endsAt         DateTime
  reason         String
  createdAt      DateTime     @default(now())

  @@index([professionalId, startsAt, endsAt])
  @@index([tenantId])
}

// Override de comisión por (profesional, servicio) (ADR-011 G18). Si existe fila
// para el par, su commissionPercent gana; si no, se usa Professional.commissionPercent.
// Tabla separada del M2M profesional↔servicio para no tocar esa relación.
model ProfessionalServiceCommission {
  id                String       @id @default(cuid())
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  tenantId          String
  professional      Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId    String
  service           Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId         String
  commissionPercent Float
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([professionalId, serviceId])
  @@index([tenantId])
}

// Recurso con capacidad limitada (ADR-011 G17): máquinas o gabinetes que varios
// servicios comparten. quantity = cuántas unidades hay (2 radiofrecuencias,
// 3 gabinetes). Al reservar se controla no superar la capacidad en el rango.
model Resource {
  id       String            @id @default(cuid())
  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  tenantId String
  name     String
  quantity Int               @default(1)
  active   Boolean           @default(true)
  services ServiceResource[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([tenantId])
}

// Cuántas unidades de un recurso consume un servicio cada vez que se realiza.
model ServiceResource {
  id         String   @id @default(cuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId  String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String
  units      Int      @default(1)

  @@unique([serviceId, resourceId])
  @@index([tenantId])
  @@index([resourceId])
}

// Plantilla editable de mensaje para el panel central de recordatorios
// (ADR-012). Una fila por (tenant, tipo, canal): p.ej. recordatorio de turno
// por email, recordatorio de turno por WhatsApp, difusión de novedad por
// WhatsApp. El body admite variables tipo {{clientName}} que el job
// interpola antes de enviar.
model MessageTemplate {
  id        String              @id @default(cuid())
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  tenantId  String
  type      MessageTemplateType
  channel   MessageChannel
  subject   String?
  body      String
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([tenantId, type, channel])
  @@index([tenantId])
}

// Novedad de un profesional (evento, promo, nueva técnica, etc.) pensada
// para difundir a clientes — distinto de ProfessionalBlock (franco/vacaciones,
// que es operativo). broadcastAt queda null hasta que se dispara el envío;
// una vez enviada no se reenvía.
model ProfessionalNews {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  message        String
  broadcastAt    DateTime?
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([professionalId])
}

// Lista de espera (BACKLOG "Media" → priorizada por ROI en docs/ANALISIS-BRECHAS.md).
// Un anotado que quiere un turno de un servicio (opcionalmente con un profesional
// preferido) cuando no había horario disponible, o que llamó/vino sin reservar. No
// se enlaza a `Client` a propósito: muchos anotados son gente que recién llama y
// todavía no es cliente; los datos de contacto se guardan sueltos y, si se convierte
// en turno, ahí sí se hace el upsert del Client por teléfono (mismo criterio que el
// turno manual). `professionalId` null = "cualquier profesional que preste el
// servicio". Cuando se resuelve como turno real, queda BOOKED con
// `bookedAppointmentId` de rastro (no es FK fuerte para que borrar el turno no
// rompa el histórico de la lista). Idempotencia del alta: no hay unique — la misma
// persona puede anotarse dos veces a propósito (dos servicios distintos); el
// duplicado exacto lo evita la UI, no el schema.
model WaitlistEntry {
  id             String         @id @default(cuid())
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  tenantId       String
  clientName     String
  clientPhone    String
  clientEmail    String?
  service        Service        @relation(fields: [serviceId], references: [id])
  serviceId      String
  professional   Professional?  @relation(fields: [professionalId], references: [id])
  professionalId String? // null = cualquier profesional
  preferenceNote String? // "martes o jueves por la tarde", texto libre
  notes          String? // nota interna de recepción
  status         WaitlistStatus @default(WAITING)
  notifiedAt     DateTime? // cuándo se le avisó que se liberó un hueco
  resolvedAt     DateTime? // cuándo pasó a BOOKED o CANCELLED
  bookedAppointmentId String? // turno con el que se resolvió (rastro, no FK)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([serviceId])
  @@index([professionalId])
}

// ─── Capability Factura + borde del Plugin ARCA (ADR-020 §6.a, ADR-022) ───
// El modelo Factura de ADR-003 "nace con el Plugin ARCA": acá es donde nace.
// Alcance mínimo a propósito (ADR-020: no materializar de forma especulativa):
// guarda lo necesario para pedir el CAE y registrar el resultado fiscal.
// El CÁLCULO de IVA vive en el Core, no en el plugin (ADR-006): los montos se
// guardan ya calculados. `docNro` es texto (un CUIT de 11 dígitos no entra en
// un Int de 32 bits). Los campos de CAE son nulos hasta que ARCA autoriza.

enum InvoiceStatus {
  PENDING // creada; esperando autorización de ARCA
  AUTHORIZED // CAE obtenido
  REJECTED // ARCA la rechazó
}

model Invoice {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  // Identidad fiscal del comprobante (códigos de catálogo de ARCA).
  puntoVenta      Int
  tipoComprobante Int? // TipoComprobante de WSFEv1 (1=A, 6=B, 11=C). Nulo hasta
  //                      la autorización: lo deriva el plugin ARCA (ADR-022) y
  //                      lo escribe `registerFiscalDocument`.
  concepto Int // 1=Productos, 2=Servicios, 3=ambos
  docTipo  Int // 80=CUIT, 96=DNI, 99=Consumidor Final
  docNro   String
  fecha    String // AAAAMMDD

  // Montos calculados por el Core (ADR-006). EXACTITUD FISCAL: Decimal(14,2) (spec §1).
  // Decisión ADR-057: el dinero se persiste en `Decimal(14,2)` (exactitud al centavo para
  // ARCA/auditoría), pero el CONTRATO del plugin/Core sigue en `number` — la conversión
  // `Decimal ↔ number` se confina al BORDE del repositorio de Invoice (lectura `.toNumber()`
  // en `facturacion-actions.ts`; la escritura acepta `number`). La migración que aplica esto
  // (`prisma/migrations/20260708120000_invoice_money_decimal`) es Gate 2 (OK del dueño).
  neto  Decimal @db.Decimal(14, 2)
  iva   Decimal @db.Decimal(14, 2) // total de IVA (suma de alícuotas); el desglose va en `ivaDesglose`.
  total Decimal @db.Decimal(14, 2)

  // Desglose de IVA por alícuota (spec §1: `iva` como `SubtotalIvaCore[]`). Se persiste
  // acá para auditoría/reimpresión; antes vivía solo en el payload (efímero) del outbox.
  ivaDesglose Json? // SubtotalIva[] = { alicuotaId, base, importe }[]

  status InvoiceStatus @default(PENDING)

  // Resultado fiscal de ARCA — nulo hasta autorización.
  cae            String?
  caeVencimiento String? // AAAAMMDD
  numero         Int? // correlativo asignado por ARCA
  rechazoMotivo  String? // detalle si status=REJECTED

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  authorizedAt DateTime? // cuándo ARCA devolvió el CAE (audit; spec §1)

  // D10 (ADR-060 ajuste 2, fiscal) — ENLACE al origen de la factura (venta que la generó).
  // Se fija AHORA porque agregarlo con facturas reales adentro es la migración más cara.
  // Aditivo: FKs nullable; las facturas existentes quedan sin origen (null) sin backfill.
  // Rastro débil (SetNull): borrar el origen no rompe el histórico fiscal. La idempotencia
  // del webhook deja de depender del parche `Payment.comprobanteNro`.
  order         Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId       String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  appointmentId String?

  @@unique([tenantId, puntoVenta, tipoComprobante, numero]) // guarda anti-duplicado de numeración fiscal (spec §1). NULLs (PENDING) no colisionan.
  @@index([tenantId, status])
  // I2 (ADR-064) — IDEMPOTENCIA comprobante↔venta 1:1: UNA factura por Order/Appointment.
  // El @@unique es la guarda a nivel DB que cierra la ventana de carrera del check-then-create
  // en `createInvoice` (dos disparos simultáneos → el 2º choca P2002 → se refetchea el ganador).
  // NULLs no colisionan en Postgres → las facturas sin origen (MP standalone / previas a D10)
  // conviven sin límite. También sirve de índice para "la factura de este pedido/turno" (D10).
  @@unique([tenantId, orderId]) // I2/D10 — 1:1 pedido↔comprobante
  @@unique([tenantId, appointmentId]) // I2/D10 — 1:1 turno↔comprobante
}

// Outbox transaccional (ADR-002): el Core escribe el evento de dominio en la
// MISMA transacción que la operación de negocio; un worker lo lee y lo despacha
// al plugin. Garantiza que una factura creada siempre termine enviada a ARCA
// aunque el proceso muera entre "guardar" y "despachar". `processedAt` nulo =
// pendiente. Genérico (no solo ARCA): `type` discrimina el evento.
model OutboxEvent {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  type    String // ej. "InvoiceCreated"
  payload Json

  processedAt DateTime? // null = pendiente de despacho
  attempts    Int       @default(0)
  lastError   String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([processedAt])
}

// --- Módulo BANCOS (plugin src/plugins/bancos + glue src/lib/bancos-*) ---
// Persistencia de la importación de extractos bancarios: el comerciante sube su
// CSV/XLSX, el plugin detecta columnas y clasifica, y esto guarda el lote + cada
// movimiento con su propuesta de factura. Migración ESCRITA y SIN aplicar a Neon
// (Gate 2). Las tres tablas tienen `tenantId` → las cubre la policy data-driven
// de RLS (re-ejecutar prisma/rls/0001_enable_rls.sql en el mismo deploy).

// De dónde salió el extracto (espeja `OrigenMovimiento` del plugin).
enum OrigenImportacionBancaria {
  banco
  mercadopago // export de actividad de MP importado por el mismo pipeline
}

enum EstadoImportacionBancaria {
  procesada // procesada automáticamente (el mapeo puede requerir confirmación)
  confirmada // el usuario confirmó/corrigió el mapeo y se re-procesó
  descartada // descartada por el usuario
}

// Clasificación de negocio del movimiento (proyección de las reglas del
// clasificador del plugin a vocabulario de producto — ver mapearClasificacion
// en src/lib/bancos-glue.ts).
enum ClasificacionMovimientoBancario {
  venta
  comision
  impuesto
  transferencia_propia
  reverso
  prestamo
  egreso
  otro
}

// Estado de la propuesta de factura (espeja `EstadoPropuesta` del plugin y suma
// `emitida`, que es un estado de PERSISTENCIA: ya se llamó a createInvoice).
enum EstadoPropuestaMovimiento {
  auto // lista para emitir sin intervención (consumidor final genérico)
  revision // espera datos/decisión humana (identificación, duplicado, cap)
  no_facturable // no es una venta (comisión/impuesto/transferencia/etc.)
  descartado // duplicado de una corrida anterior (queda solo como rastro)
  emitida // factura creada en el Core (ver invoiceId)
}

// Un extracto importado (el lote). Guarda el ARCHIVO crudo para poder
// re-procesarlo cuando el usuario confirma/corrige el mapeo (confianza < 0.8)
// sin pedirle que lo vuelva a subir — un extracto pesa KB, no compromete la DB.
model ImportacionBancaria {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  nombreArchivo    String
  origen           OrigenImportacionBancaria
  archivo          Bytes // contenido crudo (CSV/XLSX) para re-proceso y auditoría
  mapeoJson        Json // MapeoColumnas detectado/confirmado (incluye confianza)
  estado           EstadoImportacionBancaria @default(procesada)
  totalMovimientos Int                       @default(0)

  movimientos MovimientoImportado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// Un movimiento del extracto con su propuesta de factura. `hash` es el id
// idempotente del plugin (sha-256 de fecha|monto|descripción): el unique
// [tenantId, hash] hace que re-importar el mismo extracto (o dos extractos
// solapados) NO duplique movimientos entre corridas (ADR-025 §3).
model MovimientoImportado {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  importacion   ImportacionBancaria @relation(fields: [importacionId], references: [id], onDelete: Cascade)
  importacionId String

  hash        String // hash idempotente del plugin (hashMovimiento)
  fecha       String // AAAAMMDD (mismo formato que Invoice.fecha, camino fiscal)
  monto       Decimal @db.Decimal(14, 2) // con signo: + crédito / − débito (ADR-057)
  descripcion String
  contraparte String?
  referencia  String?

  clasificacion   ClasificacionMovimientoBancario
  estadoPropuesta EstadoPropuestaMovimiento

  // Datos de la propuesta (los completa la revisión cuando aplica el umbral).
  requiereIdentificacion Boolean @default(false)
  motivoRevision         String?
  docTipo                Int? // catálogo ARCA: 80=CUIT, 86=CUIL, 96=DNI, 99=consumidor final
  docNro                 String? // como texto (11 dígitos no entran en Int32, mismo criterio que Invoice.docNro)
  nombreReceptor         String?
  descripcionServicio    String?

  // Rastro a la factura emitida (sin FK a propósito: rastro débil, como el
  // resto del camino fiscal — borrar jamás una Invoice es regla aparte).
  invoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, hash])
  @@index([tenantId, estadoPropuesta])
  @@index([tenantId, importacionId])
}

// Aprendizaje del clasificador POR TENANT (persistencia real del
// `AprendizajeBancoPort` del plugin, que su propio contrato define como
// "real = tabla por tenant; stub = en memoria"). Una fila = una corrección
// del comercio/contador: "este patrón se clasifica así". Empareja por
// contraparte (prioritario) o por descripción normalizada exacta.
model ReglaClasificacionBancoTenant {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  contraparte            String? // match prioritario (lo más confiable)
  descripcionNormalizada String? // match por leyenda bancaria exacta (normalizada)
  clasificacion          String // ClasificacionBanco del plugin: FACTURABLE | NO_FACTURABLE | REVISAR

  createdAt DateTime @default(now())

  @@index([tenantId])
}

// --- Capability POS / Orden (ADR-003 "Orden/Venta", Fase 2 POS) ---
// Capability del CORE, no del blueprint carnicería: modela la venta de mostrador
// y la toma de pedido online para cualquier vertical retail. La carnicería la usa
// para vender cortes por kg; un kiosco futuro la reusa igual (decisión 2 del brief).
// El pago es registro simple (ADR-003 Fase 1: `paymentMethod` + `paid`); un ledger
// de Pago unificado (hoy `Payment` está atado a Appointment) es trabajo futuro.
// La factura fiscal la resuelve el Plugin `arca` vía outbox (ADR-022), no este modelo.
model Order {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  code        Int // correlativo legible por tenant (nº de pedido que ve el mostrador)
  status      OrderStatus     @default(PENDING)
  channel     OrderChannel    @default(COUNTER)
  fulfillment FulfillmentType @default(PICKUP)

  // Cliente: snapshot desnormalizado (un pedido de vidriera puede venir de alguien
  // sin cuenta) + link opcional a Client si es un cliente conocido del backoffice.
  client        Client?   @relation(fields: [clientId], references: [id])
  clientId      String?
  customerName  String
  customerPhone String
  address       String? // requerido por la acción si fulfillment=DELIVERY
  scheduledFor  DateTime? // horario de retiro/entrega deseado
  notes         String?

  // Totales calculados en el Core (ADR-006), snapshot al momento del pedido.
  subtotal Float @default(0)
  discount Float @default(0)
  total    Float @default(0)

  // Pago simple (ver nota de cabecera).
  paymentMethod PaymentMethod?
  paid          Boolean        @default(false)

  items         OrderItem[]
  cashMovements CashMovement[]
  collections   Collection[] // D9 — cobros (parciales/total) imputados a este pedido
  invoices      Invoice[] // D10 — facturas cuyo origen es este pedido
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model OrderItem {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId  String

  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  // Snapshot del producto al momento de la venta: el nombre/precio pueden cambiar
  // después, pero la línea del pedido conserva lo efectivamente cobrado (ADR-009 §4).
  name      String
  saleUnit  ProductSaleUnit @default(UNIT)
  quantity  Float // unidades (UNIT) o kilos (WEIGHT)
  unitPrice Float // precio unitario (UNIT) o precio/kg (WEIGHT)
  lineTotal Float

  @@index([tenantId])
  @@index([orderId])
}

// --- Capability CAJA del POS (turno de mostrador / arqueo) ---
// Modela el turno de caja del mostrador: se abre declarando un fondo inicial, se
// le registran movimientos (ventas en efectivo, ingresos, egresos, retiros) y se
// cierra haciendo un arqueo (efectivo contado vs esperado). El "esperado" NO se
// guarda como estado mutable: es una función pura del fondo inicial + los
// movimientos (ver src/lib/caja), y se CONGELA al cerrar (closingExpected) junto
// con lo contado (closingCounted) y la diferencia — así el cierre es un histórico
// inmutable, no un cálculo que cambia si después se toca un movimiento.
//
// Alcance mínimo (gobierno calidad-vs-costo): un solo mostrador por tenant, sin
// multi-caja ni multi-terminal — la lógica de "una sola sesión abierta a la vez"
// vive en el dominio, no en un índice parcial de Postgres.
model CashSession {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  status CashSessionStatus @default(OPEN)

  // Apertura: quién abrió (actor "user:<id>", igual que el audit trail) y con qué
  // fondo declarado. `openingFloat` es el efectivo con el que arranca el cajón.
  openedBy     String
  openingFloat Float    @default(0)
  openedAt     DateTime @default(now())

  // Cierre — nulo mientras la sesión está OPEN. Al cerrar se congela el arqueo:
  //   closingExpected = openingFloat + Σ ingresos − Σ egresos (calculado, ADR-006)
  //   closingCounted  = efectivo realmente contado en el cajón (lo declara quien cierra)
  //   closingDiff     = closingCounted − closingExpected (faltante < 0 / sobrante > 0)
  closedBy        String?
  closingExpected Float?
  closingCounted  Float?
  closingDiff     Float?
  closingNote     String?
  closedAt        DateTime?

  movements CashMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, openedAt])
}

// Movimiento de dinero dentro de un turno de caja. El monto SIEMPRE es positivo;
// el signo (suma o resta al esperado) lo decide `type` en la lógica de arqueo
// (src/lib/caja), no la fila — así el registro es auditable y no ambiguo. La
// APERTURA se materializa como un movimiento propio (además de openingFloat) para
// que el listado del turno sea un ledger completo de principio a fin.
// `orderId` es una referencia opcional y débil (SetNull): un movimiento VENTA
// puede apuntar al Order que lo originó, pero borrar el pedido no rompe el arqueo.
model CashMovement {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  type   CashMovementType
  amount Float // siempre > 0; el signo lo aplica el arqueo según `type`
  reason String? // motivo/descripción (obligatorio en la UI para INGRESO/EGRESO/RETIRO)

  // Rastro opcional al pedido que originó el movimiento (VENTA en efectivo).
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId String?

  createdBy String // actor "user:<id>"
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([sessionId, createdAt])
  @@index([orderId])
}

// --- Capability COMPRAS / REPOSICIÓN de stock del POS ---
// Contracara de la venta: la venta (order-core.ts) DESCUENTA stock; la
// compra/reposición lo REPONE. Un documento StockPurchase agrupa las líneas de una
// entrada de mercadería (compra a proveedor o reposición interna) y, al registrarse,
// INCREMENTA de forma atómica el `stock` de cada producto (ver
// src/lib/stock/purchase-core.ts). No hay guarda anti-oversell: reponer nunca falla
// por falta de stock (sumar siempre puede), a diferencia de la venta.
//
// Alcance mínimo (gobierno calidad-vs-costo): sin maestro de Proveedores (el
// proveedor es un snapshot de texto opcional) y sin estados/aprobación — la entrada
// se aplica en el acto y es un histórico inmutable. Si más adelante hace falta un
// maestro de proveedores o remitos pendientes de recepción, se agrega en su propio
// ADR sin tocar este núcleo.

// Tipo de entrada de stock. COMPRA = ingreso con costo, típicamente contra un
// proveedor (alimenta análisis de margen a futuro). REPOSICION = reposición/ajuste
// de existencias hacia arriba sin costo obligatorio (recuento, devolución, traspaso).
enum StockPurchaseKind {
  COMPRA
  REPOSICION
}

// Documento de entrada de stock (compra/reposición). El `code` es un correlativo
// legible por tenant (igual criterio que Order). `totalCost` es un snapshot del
// costo total al momento de registrar (ADR-006/-009): el costo de cada línea se
// congela aunque después cambie el precio de compra del producto.
model StockPurchase {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  code     Int
  kind     StockPurchaseKind @default(COMPRA)
  supplier String? // snapshot del proveedor (texto libre) — se CONSERVA como fallback/snapshot
  notes    String?

  // D1/D6 (ADR-060) — link OPCIONAL al proveedor maestro. Aditivo: FK nullable; las compras
  // existentes quedan con `supplierId` null y su `supplier` texto intacto (sin backfill).
  supplierRef Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId  String?

  totalCost Float @default(0)

  createdBy String // actor "user:<id>"
  items     StockPurchaseItem[]
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
  @@index([tenantId, createdAt])
  @@index([tenantId, supplierId]) // D1 — "compras de este proveedor" (para cuentas a pagar)
}

// Línea de una entrada de stock: qué producto y cuánto ingresó. Snapshotea
// nombre/unidad/costo como OrderItem congela lo vendido (ADR-009 §4), así el remito
// conserva lo efectivamente ingresado aunque el producto cambie o se borre después.
// `productId` es una referencia débil (SetNull): borrar el producto no rompe el
// histórico de compras.
model StockPurchaseItem {
  id         String @id @default(cuid())
  tenant     Tenant @relation(fields: [tenantId], references: [id])
  tenantId   String
  purchase   StockPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  // Snapshot del producto al momento de la entrada.
  name      String
  unit      String @default("unidades")
  quantity  Float // cantidad que ingresó al stock (en `unit`)
  unitCost  Float  @default(0) // costo unitario de compra (0 en reposiciones sin costo)
  lineTotal Float  @default(0) // quantity × unitCost, redondeado

  @@index([tenantId])
  @@index([purchaseId])
}

// --- Ledger de stock: la única fuente de verdad de cómo se mueve el inventario ---
// Cada cambio de `Product.stock` (venta, compra/reposición, consumo de insumo al
// completar un turno, ajuste/merma manual) escribe UNA fila acá, dentro de la misma
// transacción que muta el stock (ver src/lib/stock/ledger.ts: `recordMovement` es el
// único mutador). `Product.stock` pasa a ser una proyección cacheada; este ledger es
// la historia auditable que responde "por qué el stock es X" y "qué se movió".
//
// Convención de signo: `qty` es FIRMADA — positiva entra, negativa sale. El signo lo
// fija el TIPO en un solo lugar (VENTA/CONSUMO restan; COMPRA/REPOSICION suman; AJUSTE
// lleva el signo del delta declarado). `balanceAfter` congela el stock resultante tras
// aplicar el movimiento, para reconstruir el timeline sin re-sumar todo el ledger.
//
// Las referencias al origen (orderId/purchaseId/appointmentId) son rastros DÉBILES:
// columnas sueltas sin FK a propósito (audit trail), para no acoplar el ledger a los
// ciclos de vida de Order/StockPurchase/Appointment ni inflar sus back-relations.
enum StockMovementType {
  VENTA                // salida por venta en el POS/vidriera (order-core)
  COMPRA               // entrada por compra a proveedor
  REPOSICION           // entrada por reposición interna
  CONSUMO              // salida por consumo de insumo al completar un turno (ServiceProduct)
  AJUSTE               // ajuste manual: recuento, merma, rotura, vencimiento (signo del delta)
  DEVOLUCION_PROVEEDOR // salida: mercadería que se devuelve al proveedor (D4, ADR-060). Revierte COGS al costo original; rastro al StockPurchase. La pata financiera va en AccountPayable.
}

model StockMovement {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  type         StockMovementType
  qty          Float // FIRMADA: + entra / − sale
  unitCost     Float? // costo unitario snapshot (entradas; null en salidas/ajustes sin costo)
  balanceAfter Float // stock del producto tras aplicar este movimiento (proyección congelada)
  reason       String? // motivo (obligatorio en AJUSTE: recuento/merma/rotura)

  // Rastros débiles al origen (sin FK): de dónde salió el movimiento.
  orderId       String?
  purchaseId    String?
  appointmentId String?

  createdBy String // actor "user:<id>" (o "system" para automáticos)
  createdAt DateTime @default(now())

  @@index([tenantId, productId, createdAt])
  @@index([tenantId, createdAt])
}

// ============================================================================
// FASE C/C.5 de ADR-060 — entidades FUNDACIONALES, todas ADITIVAS (no aplicadas a
// prod: migraciones preparadas + rollback, §C · Gate 2). Ver
// docs/estrategia/estructura-consolidada-producto.md (ADR-060).
// ============================================================================

// --- D1 · Supplier (proveedor maestro) ---
// El PRERREQUISITO (cuello) de compras formal (D6), devoluciones (D4) y cuentas a
// pagar (D2). Hoy `StockPurchase.supplier` es TEXTO LIBRE (snapshot); este maestro le
// da identidad estable (razón social + CUIT) para poder deber/pagar/devolver a un
// proveedor concreto. Aditivo: `StockPurchase.supplierId` es FK NULLABLE y el `supplier`
// texto se conserva como fallback → ninguna compra existente se rompe ni requiere backfill.
model Supplier {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name  String // razón social
  // CUIT de 11 dígitos sin guiones (mismo criterio que `Tenant.arcaCuit`/`Invoice.docNro`:
  // String, no Int — un CUIT no entra en Int32). Único por tenant cuando está presente;
  // varios NULL conviven (Postgres no colisiona NULLs en un UNIQUE).
  taxId String?
  email String?
  phone String?
  notes String?
  active Boolean @default(true) // baja lógica: nunca se borra un proveedor con historial

  purchases StockPurchase[] // back-relation de la FK nullable en StockPurchase (D6)
  payables  AccountPayable[] // D2 — cuentas a pagar a este proveedor

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, taxId]) // un CUIT único por tenant (NULLs no colisionan)
  @@index([tenantId])
}

// --- D9 · Collection / Receipt (cobranza / settlement unificado) ---
// El HUECO CRÍTICO que marcó la revisión de Opus (ADR-060 §0.1): hoy servicios cobran con
// `Payment` (1:1 con Appointment) y retail con `Order.paid` (booleano) — NINGUNO soporta
// COBROS PARCIALES contra un saldo, que es justo lo que el fiado necesita. `Collection`
// registra cada cobro (parcial o total) contra un origen; el SALDO es una función pura del
// total imputado menos la suma de sus Collections (ver src/lib/settlement/collection.ts).
//
// Entidad NUEVA a propósito (ADR-060 ajuste 1): NO se muta `Payment` (relajar su `@unique`
// no sería aditivo puro). `Payment`/`Order.paid` siguen intactos → aditividad 100%.
//
// Origen POLIMÓRFICO (Order | Appointment | AccountReceivable): FK nullable a los que YA
// existen (Order/Appointment); para RECEIVABLE (D3, aún sin tabla) se usa `originId` (rastro
// débil) hasta que exista — el discriminador `originType` lo hace explícito. `originId`
// SIEMPRE está seteado (== el id del origen), así el saldo se computa sin depender de la FK.
enum CollectionOriginType {
  ORDER
  APPOINTMENT
  RECEIVABLE // AccountReceivable (D3) — deuda del cliente (fiado), se cobra
  PAYABLE // AccountPayable (D2) — deuda al proveedor, se paga (Collection = movimiento de settlement, in o out)
}

model Collection {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  originType CollectionOriginType
  originId   String // id del origen (siempre presente; fuente de verdad para agrupar/saldar)

  // FKs NULLABLES a los orígenes ya existentes (integridad referencial donde se puede).
  // RECEIVABLE viaja solo por `originId` hasta que D3 exista. Rastros débiles: borrar el
  // origen no debe romper el histórico de cobros → SetNull.
  order         Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId       String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  appointmentId String?

  // Monto de ESTE cobro (parcial o total). Decimal(14,2) en persistencia (ADR-057); el
  // contrato del Core es `number`, con la conversión confinada al borde del repositorio.
  amount Decimal       @db.Decimal(14, 2)
  method PaymentMethod
  note   String?

  collectedBy String // actor "user:<id>" que registró el cobro (audit)
  createdAt   DateTime @default(now())

  @@index([tenantId, originType, originId]) // "todos los cobros de este origen" → para saldar
  @@index([tenantId, createdAt])
}

// ============================================================================
// FASE D/E de ADR-060 — entidades de DEUDA, todas ADITIVAS (migraciones preparadas +
// rollback, §C · Gate 2). Consumen las fundaciones D1 (Supplier) y D9 (Collection).
// ============================================================================

// Estado de vida de una deuda (AP/AR). El SALDO/estado de pago (parcial/pago) NO se
// guarda acá — es una función pura de la suma de `Collection` imputadas (fuente de verdad
// única, sin drift). `status` es solo el ciclo de vida: OPEN (viva) / VOID (anulada, p. ej.
// cargada por error o cubierta por una nota de crédito).
enum DebtStatus {
  OPEN
  VOID
}

// Estado de un cheque diferido (D2). Ver la máquina de estados pura en src/lib/debts/cheque.ts.
// Solo CLEARED mueve plata (genera un Collection que baja el saldo de la AP).
enum ChequeStatus {
  PENDING // en cartera, aún no entregado
  DELIVERED // entregado al proveedor, esperando su fecha/acreditación
  CLEARED // acreditado: pagó de verdad
  BOUNCED // rechazado (sin fondos)
  CANCELED // anulado antes de acreditar
}

// --- D2 · AccountPayable (cuentas a pagar al proveedor) ---
// Deuda a un proveedor (típicamente de una compra). El SALDO = `amount` − suma de los
// `Collection` con originType=PAYABLE y originId = este id (pagos parciales/total; los
// cheques que ACREDITAN generan esos Collection). El aging sale de `dueDate` (src/lib/debts).
// Aditiva: tabla nueva, FK a Supplier (Restrict: no borrar un proveedor con deuda viva).
model AccountPayable {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  supplier   Supplier @relation(fields: [supplierId], references: [id])
  supplierId String

  amount    Decimal    @db.Decimal(14, 2) // total adeudado (congelado)
  concept   String? // detalle ("Factura A 0001-00012345", etc.)
  issueDate DateTime   @default(now()) // fecha de la deuda (para aging)
  dueDate   DateTime? // vencimiento pactado (null = sin vencimiento)
  status    DebtStatus @default(OPEN)

  // Rastro débil a la compra que la originó (sin FK, igual criterio que StockMovement).
  purchaseId String?

  cheques   PayableCheque[]
  createdBy String // actor "user:<id>"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, dueDate])
}

// Cheque diferido entregado (o a entregar) para cancelar una deuda a proveedor (D2).
// Su fecha `dueDate` es la fecha DIFERIDA (cuándo se cobra). Mientras no acredita es un
// compromiso; al acreditar (CLEARED) se asienta el pago como `Collection`.
model PayableCheque {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  payable   AccountPayable @relation(fields: [payableId], references: [id], onDelete: Cascade)
  payableId String

  chequeNumber String
  bank         String
  amount       Decimal      @db.Decimal(14, 2)
  issueDate    DateTime     @default(now()) // fecha de emisión
  dueDate      DateTime // fecha DIFERIDA (acreditación)
  status       ChequeStatus @default(PENDING)
  endorsedTo   String? // endoso: a quién se endosó, si se endosó

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, payableId])
  @@index([tenantId, status, dueDate]) // "cheques por vencer/acreditar" → cash-flow
}

// --- D3 · AccountReceivable (cuentas a cobrar / fiado del cliente) ---
// Deuda que un cliente tiene con el negocio (fiado). El SALDO = `amount` − suma de los
// `Collection` con originType=RECEIVABLE y originId = este id (cobros parciales/total). El
// aging sale de `dueDate`. Default-OFF por rubro (fiado es cultura de comercio de barrio);
// Comercio ve el fiado light (sin vencimiento), Empresa suma vencimiento/recordatorio.
// Aditiva: tabla nueva, FK a Client (Restrict: no borrar un cliente con deuda viva).
model AccountReceivable {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  amount    Decimal    @db.Decimal(14, 2) // total fiado (congelado)
  concept   String? // detalle ("Pedido #1234", "cuenta corriente", etc.)
  issueDate DateTime   @default(now())
  dueDate   DateTime? // vencimiento (null = fiado light sin vencimiento, perfil Comercio)
  status    DebtStatus @default(OPEN)

  // Rastro débil al pedido que la originó (sin FK).
  orderId String?

  createdBy String // actor "user:<id>"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, dueDate])
}

// ============================================================================
// Módulo CARTERA (producto Contador, ADR-025 §12 + ADR-045) — ASIGNACIÓN explícita
// estudio contable → cliente administrado (patrón VARIANTE, ADR-055).
// ============================================================================
//
// Cada cliente del contador ES un Tenant del ERP (aislamiento RLS gratis, módulos
// asignables, upgrade natural al producto completo sin migrar datos). El estudio
// contable TAMBIÉN es un Tenant. Esta tabla es la relación explícita con su ABM
// propio (nunca "todos con todo").
//
// RLS — decisión deliberada: la columna del ESTUDIO se llama `tenantId` (el estudio
// es el DUEÑO de la fila: su cartera es SU dato). Así la policy data-driven de
// `prisma/rls/0001_enable_rls.sql` (que cubre toda tabla de `public` con columna
// `tenantId`) la protege SOLA, sin caso especial: con el GUC del estudio se ven solo
// sus filas; el cliente (GUC = clienteTenantId) NO ve la cartera de nadie. El código
// además filtra SIEMPRE por `tenantId` explícito (defensa en profundidad, ADR-018).
// `clienteTenantId` es la referencia asignada; NO da acceso por sí sola — los datos
// del cliente se leen únicamente vía tenantTransaction(clienteTenantId) tras
// verificar la pertenencia a la cartera (src/lib/cartera-core.ts).

// Estado de la asignación estudio→cliente. `baja` conserva la fila (historial +
// idempotencia del alta); solo `activa` permite operar sobre el cliente.
enum EstadoCarteraCliente {
  activa
  pausada
  baja
}

model CarteraCliente {
  id String @id @default(cuid())

  // El ESTUDIO contable dueño de la fila (por eso `tenantId`: la policy RLS
  // data-driven cubre esta tabla igual que a cualquier otra tabla de tenant).
  tenant   Tenant @relation("CarteraDelEstudio", fields: [tenantId], references: [id])
  tenantId String

  // El CLIENTE administrado (también un Tenant). Restrict: no se borra un tenant
  // que está en una cartera.
  clienteTenant   Tenant @relation("CarteraComoCliente", fields: [clienteTenantId], references: [id])
  clienteTenantId String

  // Nombre corto con el que el contador conoce al cliente ("Kiosco de Marta").
  alias  String
  estado EstadoCarteraCliente @default(activa)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, clienteTenantId]) // un cliente entra UNA vez a la cartera de un estudio
  @@index([tenantId])
  @@index([clienteTenantId]) // lookup inverso: ¿en qué carteras está este tenant?
}
