// Prisma schema — Estetica ERP (Fase 1 del blueprint "Servicios", ADR-010)
// Multi-tenant a nivel de datos (ADR-001 / G1): toda tabla de negocio lleva
// `tenantId`. Hoy hay un solo tenant (Beauty & Spa); el aislamiento es a nivel
// de aplicación vía src/lib/tenant.ts. RLS de Postgres se activa con el 2º
// tenant (ver nota en el modelo Tenant).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentMethod {
  MERCADOPAGO
  EFECTIVO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

// Tipo de mensaje que arma el panel de recordatorios (ADR-012). Cada tipo
// tiene su propia plantilla editable por tenant; el canal (email/whatsapp)
// es un atributo de la plantilla, no del tipo, porque el mismo aviso puede
// mandarse por ambos canales con textos distintos.
enum MessageTemplateType {
  APPOINTMENT_REMINDER
  PROFESSIONAL_NEWS_BROADCAST
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

// Estado de un anotado en la lista de espera. WAITING = esperando un hueco;
// NOTIFIED = recepción ya le avisó que se liberó algo (aún sin reservar);
// BOOKED = se convirtió en turno real (queda el histórico + bookedAppointmentId);
// CANCELLED = se dio de baja (ya no quiere o se resolvió por otro lado).
enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  CANCELLED
}

// Rol de un usuario del panel (ADR-017 §2.b / ADR-009 §3). Enum fijo de 3, sin
// editor granular a propósito: negocios chicos quieren roles con nombres que
// entienden, no una matriz de permisos. OWNER absorbe el "admin" de hoy.
enum UserRole {
  OWNER
  RECEPTION
  PROFESSIONAL
}

// Tenant (negocio) — raíz del aislamiento multi-tenant (ADR-001). Cada tabla de
// negocio referencia un tenant. Por ahora hay uno solo (Beauty & Spa); el
// modelo nace preparado para muchos sin rediseñar. La zona horaria vive acá
// (AMD-004: config del tenant, no del servidor).
// NOTA (ADR-010 G1): la mitad de RLS de ADR-001 (ENABLE ROW LEVEL SECURITY +
// contexto de tenant por transacción) se difiere hasta el 2º tenant — con uno
// solo, y con la resolución de tenant fail-closed (ADR-015: getCurrentTenantId()
// lanza error si hay ≠1 tenant), no hay leak cross-tenant posible; RLS+pooling es
// el punto más riesgoso de tocar sin necesidad.
// El aislamiento hoy es a nivel de aplicación (tenantId en cada create/read).
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("America/Argentina/Buenos_Aires")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boxes           Box[]
  boxBlocks       BoxBlock[]
  professionals   Professional[]
  workingHours    WorkingHours[]
  services        Service[]
  products        Product[]
  serviceProducts ServiceProduct[]
  clients         Client[]
  appointments    Appointment[]
  reviews         Review[]
  payments        Payment[]
  auditLogs       AuditLog[]
  serviceCategories ServiceCategory[]
  professionalBlocks ProfessionalBlock[]
  serviceCommissions ProfessionalServiceCommission[]
  resources          Resource[]
  serviceResources   ServiceResource[]
  messageTemplates   MessageTemplate[]
  professionalNews   ProfessionalNews[]
  coupons            Coupon[]
  users              User[]
  businessSettings   BusinessSettings?
  commissionPayouts  CommissionPayout[]
  waitlistEntries    WaitlistEntry[]
  invoices           Invoice[]
  outboxEvents       OutboxEvent[]
}

// Configuración de localización y contacto del negocio (módulo Localización).
// Singleton por tenant (un negocio = una ficha; `tenantId` es único). Alimenta el
// bloque público "Dónde estamos / Cómo llegar", el footer y el hero del sitio,
// que antes tenían estos datos hardcodeados en el código y en business-config.ts.
// Todos los campos son opcionales A PROPÓSITO: si están vacíos, el sitio cae a los
// valores por defecto (src/lib/settings.ts), así la web nunca queda rota por falta
// de configuración. Los horarios acá son una LEYENDA pública (texto libre); los
// horarios operativos reales siguen viviendo por profesional en WorkingHours.
model BusinessSettings {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    String   @unique
  shortLabel  String? // "eyebrow" del hero: "La Alameda · Canning"
  addressLine String? // "Barrio La Alameda, Canning"
  city        String? // "Buenos Aires"
  hoursLabel  String? // "Lun a sáb · 9 a 19 h"
  whatsapp    String? // solo dígitos (formato wa.me); reemplaza el número de business-config.ts
  email       String?
  instagram   String? // handle o URL
  mapsUrl     String? // URL de mapa; si es null, se arma desde addressLine + city
  contactNote String? // leyenda de contacto del footer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Usuario del panel admin (ADR-017). Identidad propia, NO se reusa Professional:
// el dueño y la recepción no son profesionales, y no todo profesional tiene login.
// email es el identificador de login, único por tenant. passwordHash con scrypt
// (formato scrypt$<salt>$<hash>, ver src/lib/auth-password.ts). professionalId
// enlaza opcionalmente a un Professional cuando el usuario además opera su agenda.
model User {
  id             String        @id @default(cuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tenantId       String
  name           String
  email          String
  passwordHash   String
  role           UserRole
  active         Boolean       @default(true)
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?       @unique
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

// Categoría de servicios (ADR-011 G16): agrupa el catálogo (Faciales, Masajes,
// Spa, etc.). Ordenable para controlar cómo se muestra en la web y el admin.
model ServiceCategory {
  id       String    @id @default(cuid())
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  tenantId String
  name     String
  order    Int       @default(0)
  services Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, order])
}

model Box {
  id            String         @id @default(cuid())
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  tenantId      String
  name          String
  active        Boolean        @default(true)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  professionals Professional[]
  appointments  Appointment[]
  blocks        BoxBlock[]

  @@index([tenantId])
}

// Bloquea un box durante un rango de fechas (ej. reservado para un servicio
// especial) sin tener que reasignar el box fijo de cada profesional.
model BoxBlock {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  box       Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  boxId     String
  startsAt  DateTime
  endsAt    DateTime
  reason    String
  createdAt DateTime @default(now())

  @@index([boxId, startsAt, endsAt])
  @@index([tenantId])
}

model Professional {
  id                String        @id @default(cuid())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  tenantId          String
  name              String
  email             String?
  phone             String?
  active            Boolean       @default(true)
  box               Box?          @relation(fields: [boxId], references: [id])
  boxId             String?
  commissionPercent Float         @default(0)
  deletedAt         DateTime?
  services          Service[]     @relation("ProfessionalServices")
  appointments      Appointment[]
  reviews           Review[]
  workingHours      WorkingHours[]
  blocks            ProfessionalBlock[]
  serviceCommissions ProfessionalServiceCommission[]
  news              ProfessionalNews[]
  user              User?
  commissionPayouts CommissionPayout[]
  waitlistEntries   WaitlistEntry[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId])
}

// Horario de trabajo de un profesional para un día de la semana
// (0 = domingo ... 6 = sábado). Si un profesional no tiene fila para un
// día, se considera que no trabaja ese día.
model WorkingHours {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  dayOfWeek      Int
  startTime      String // "09:00"
  endTime        String // "19:00"

  @@unique([professionalId, dayOfWeek])
  @@index([tenantId])
}

model Service {
  id            String           @id @default(cuid())
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  tenantId      String
  category      ServiceCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  name          String
  description   String?
  durationMin   Int
  price         Float
  // Precio preferencial para vecinos de La Alameda (ADR-013). Opcional a
  // propósito: no todos los servicios tienen diferencial — si es null, el
  // servicio cobra `price` para todos. Nunca se muestra como "recargo" al
  // resto, siempre como beneficio vecino.
  residentPrice Float?
  // Seña obligatoria (ADR-014): monto fijo que hay que abonar para confirmar
  // el turno. Opcional por servicio, igual que residentPrice — null = no
  // exige seña. El cobro en sí sigue siendo manual (confirmPayment) hasta
  // que se conecte Mercado Pago Checkout; esto solo hace visible la
  // condición al cliente antes de reservar, como ya hace el negocio hoy.
  depositAmount Float?
  active        Boolean          @default(true)
  deletedAt     DateTime?
  professionals Professional[]   @relation("ProfessionalServices")
  appointments  Appointment[]
  products      ServiceProduct[]
  resources     ServiceResource[]
  serviceCommissions ProfessionalServiceCommission[]
  waitlistEntries WaitlistEntry[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Config de recordatorio por servicio (ADR-012 / panel de recordatorios).
  // Si reminderEnabled es false, el job de recordatorios se lo salta aunque
  // el turno esté confirmado. reminderHoursBefore reemplaza la ventana fija
  // de 24hs que tenía el job original.
  reminderEnabled     Boolean @default(true)
  reminderHoursBefore Int     @default(24)

  @@index([tenantId])
  @@index([categoryId])
}

// Insumo de stock (ej. cera, crema, guantes).
model Product {
  id           String           @id @default(cuid())
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  tenantId     String
  name         String
  unit         String           @default("unidades")
  stock        Float            @default(0)
  lowStockAt   Float            @default(5)
  active       Boolean          @default(true)
  deletedAt    DateTime?
  services     ServiceProduct[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId])
}

// Cuánto de un producto consume un servicio cada vez que se realiza.
// Al completar un turno se descuenta quantity del stock del producto.
model ServiceProduct {
  id        String  @id @default(cuid())
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  tenantId  String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Float   @default(1)

  @@unique([serviceId, productId])
  @@index([tenantId])
}

model Client {
  id           String        @id @default(cuid())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  tenantId     String
  name         String
  phone        String
  email        String?
  notes        String?
  birthDate    DateTime?
  // Vecino/a de La Alameda (ADR-013): lo responde el cliente al reservar.
  // Null = todavía no se le preguntó (clientes previos a esta feature).
  isResident   Boolean?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
}

model Appointment {
  id             String            @id @default(cuid())
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  tenantId       String
  client         Client            @relation(fields: [clientId], references: [id])
  clientId       String
  professional   Professional      @relation(fields: [professionalId], references: [id])
  professionalId String
  service        Service           @relation(fields: [serviceId], references: [id])
  serviceId      String
  box            Box               @relation(fields: [boxId], references: [id])
  boxId          String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(PENDING)
  // Precio del servicio congelado al momento de reservar (AMD-003): el precio
  // del servicio puede cambiar entre la reserva y el cobro; esto evita la
  // discusión con el cliente. Nullable para los turnos previos a esta feature.
  priceAtBooking Float?
  // Si el precio congelado arriba fue el preferencial de vecino (ADR-013) —
  // separado de Client.isResident porque el cliente puede cambiar de
  // respuesta entre turnos; esto es historial, no estado actual.
  isResidentBooking Boolean @default(false)
  // Cupón aplicado al reservar (ADR-014), si lo hubo — historial, no relación
  // fuerte a Coupon para que el turno no se rompa si el cupón se borra.
  couponCode     String?
  discountAmount Float             @default(0)
  // Nota libre de la recepción (AMD-003): "quiere el mismo tono de la vez pasada".
  notes          String?
  payment        Payment?
  review         Review?
  reminderSentAt DateTime?
  // Liquidación de comisiones (BACKLOG "Alta prioridad"). La comisión de un turno
  // se devenga cuando está COMPLETED con pago APPROVED; queda "pendiente de pago"
  // mientras este campo es null. Al liquidar un período, el turno se estampa con
  // el payout que lo cubrió — así "pendiente" = COMPLETED + pago APPROVED +
  // commissionPayoutId null, y volver a liquidar no puede doble-pagar (structural).
  commissionPayout   CommissionPayout? @relation(fields: [commissionPayoutId], references: [id])
  commissionPayoutId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([professionalId, startsAt])
  @@index([boxId, startsAt])
  @@index([tenantId, startsAt])
  @@index([commissionPayoutId])
}

// Liquidación de comisiones a un profesional por un período (BACKLOG "Alta
// prioridad"). Antes las comisiones se calculaban al vuelo en Reportes pero no
// había forma de marcar un período como pagado ni histórico — la dueña no podía
// saber si ya le había pagado a un profesional. Cada payout congela el monto
// liquidado y agrupa los turnos que cubrió (Appointment.commissionPayoutId), de
// modo que el pago es idempotente: los turnos ya estampados salen del pendiente
// y no se pueden liquidar dos veces. periodStart/End son el rango real de turnos
// cubiertos (min/max de startsAt), no un rango elegido a mano, para que el
// comprobante refleje exactamente lo que se pagó.
model CommissionPayout {
  id               String        @id @default(cuid())
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  tenantId         String
  professional     Professional  @relation(fields: [professionalId], references: [id])
  professionalId   String
  amount           Float // comisión total liquidada (congelada)
  appointmentCount Int // cuántos turnos completados cubrió
  periodStart      DateTime // startsAt más temprano cubierto (UTC)
  periodEnd        DateTime // startsAt más tardío cubierto (UTC)
  note             String? // nota libre del comprobante (ej. "pagado por transferencia")
  settledBy        String // actor que liquidó ("user:<id>"), para el audit
  appointments     Appointment[]
  createdAt        DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([professionalId])
}

// Reseña rápida que el cliente puede dejar una vez que el turno se completó.
// "published" la controla el dueño del negocio antes de que se vea en la web.
model Review {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId  String       @unique
  professional   Professional @relation(fields: [professionalId], references: [id])
  professionalId String
  clientName     String
  rating         Int
  comment        String?
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([tenantId])
}

model Payment {
  id              String        @id @default(cuid())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  appointmentId   String        @unique
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  mpPaymentId     String?
  mpPreferenceId  String?
  comprobanteNro  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
}

enum CouponType {
  PERCENT
  FIXED
}

// Cupón de descuento (ADR-014). Se valida y aplica al reservar (createAppointment
// / createBookingFromModal / createManualAppointment), nunca confiando en el
// descuento que calculó el cliente — el server vuelve a calcularlo.
model Coupon {
  id        String     @id @default(cuid())
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  tenantId  String
  code      String
  type      CouponType
  value     Float // % (0-100) si type=PERCENT, monto fijo si type=FIXED
  active    Boolean    @default(true)
  expiresAt DateTime?
  maxUses   Int? // null = sin límite
  usedCount Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

// Registro append-only de mutaciones de negocio (ADR-009 §4). Se puebla desde
// un único helper (src/lib/audit.ts) invocado por la capa de server actions —
// un solo punto de intercepción, no triggers dispersos. Es Fase 1, no Fase 3:
// retrofitearlo después dejaría un agujero histórico permanente.
model AuditLog {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  actor     String // quién: "admin", "cliente:<telefono>", "system"
  action    String // "create" | "update" | "confirm_payment" | "complete" | "cancel" | "no_show" | "delete" | ...
  entity    String // "Appointment" | "Service" | "Box" | "Product" | "Professional" | "Review" | ...
  entityId  String?
  changes   Json? // detalle / diff antes-después
  channel   String? // "admin" | "public"
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([tenantId, createdAt])
}

// Bloqueo de agenda por profesional (ADR-011 G9): franco, vacaciones, o novedad
// puntual en la que el profesional no está. Análogo a BoxBlock pero por persona.
// Recorta la disponibilidad que da WorkingHours para fechas concretas.
model ProfessionalBlock {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  startsAt       DateTime // UTC (AMD-004)
  endsAt         DateTime
  reason         String
  createdAt      DateTime     @default(now())

  @@index([professionalId, startsAt, endsAt])
  @@index([tenantId])
}

// Override de comisión por (profesional, servicio) (ADR-011 G18). Si existe fila
// para el par, su commissionPercent gana; si no, se usa Professional.commissionPercent.
// Tabla separada del M2M profesional↔servicio para no tocar esa relación.
model ProfessionalServiceCommission {
  id                String       @id @default(cuid())
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  tenantId          String
  professional      Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId    String
  service           Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId         String
  commissionPercent Float
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([professionalId, serviceId])
  @@index([tenantId])
}

// Recurso con capacidad limitada (ADR-011 G17): máquinas o gabinetes que varios
// servicios comparten. quantity = cuántas unidades hay (2 radiofrecuencias,
// 3 gabinetes). Al reservar se controla no superar la capacidad en el rango.
model Resource {
  id       String            @id @default(cuid())
  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  tenantId String
  name     String
  quantity Int               @default(1)
  active   Boolean           @default(true)
  services ServiceResource[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([tenantId])
}

// Cuántas unidades de un recurso consume un servicio cada vez que se realiza.
model ServiceResource {
  id         String   @id @default(cuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId  String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String
  units      Int      @default(1)

  @@unique([serviceId, resourceId])
  @@index([tenantId])
  @@index([resourceId])
}

// Plantilla editable de mensaje para el panel central de recordatorios
// (ADR-012). Una fila por (tenant, tipo, canal): p.ej. recordatorio de turno
// por email, recordatorio de turno por WhatsApp, difusión de novedad por
// WhatsApp. El body admite variables tipo {{clientName}} que el job
// interpola antes de enviar.
model MessageTemplate {
  id        String              @id @default(cuid())
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  tenantId  String
  type      MessageTemplateType
  channel   MessageChannel
  subject   String?
  body      String
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([tenantId, type, channel])
  @@index([tenantId])
}

// Novedad de un profesional (evento, promo, nueva técnica, etc.) pensada
// para difundir a clientes — distinto de ProfessionalBlock (franco/vacaciones,
// que es operativo). broadcastAt queda null hasta que se dispara el envío;
// una vez enviada no se reenvía.
model ProfessionalNews {
  id             String       @id @default(cuid())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  tenantId       String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  message        String
  broadcastAt    DateTime?
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([professionalId])
}

// Lista de espera (BACKLOG "Media" → priorizada por ROI en docs/ANALISIS-BRECHAS.md).
// Un anotado que quiere un turno de un servicio (opcionalmente con un profesional
// preferido) cuando no había horario disponible, o que llamó/vino sin reservar. No
// se enlaza a `Client` a propósito: muchos anotados son gente que recién llama y
// todavía no es cliente; los datos de contacto se guardan sueltos y, si se convierte
// en turno, ahí sí se hace el upsert del Client por teléfono (mismo criterio que el
// turno manual). `professionalId` null = "cualquier profesional que preste el
// servicio". Cuando se resuelve como turno real, queda BOOKED con
// `bookedAppointmentId` de rastro (no es FK fuerte para que borrar el turno no
// rompa el histórico de la lista). Idempotencia del alta: no hay unique — la misma
// persona puede anotarse dos veces a propósito (dos servicios distintos); el
// duplicado exacto lo evita la UI, no el schema.
model WaitlistEntry {
  id             String         @id @default(cuid())
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  tenantId       String
  clientName     String
  clientPhone    String
  clientEmail    String?
  service        Service        @relation(fields: [serviceId], references: [id])
  serviceId      String
  professional   Professional?  @relation(fields: [professionalId], references: [id])
  professionalId String? // null = cualquier profesional
  preferenceNote String? // "martes o jueves por la tarde", texto libre
  notes          String? // nota interna de recepción
  status         WaitlistStatus @default(WAITING)
  notifiedAt     DateTime? // cuándo se le avisó que se liberó un hueco
  resolvedAt     DateTime? // cuándo pasó a BOOKED o CANCELLED
  bookedAppointmentId String? // turno con el que se resolvió (rastro, no FK)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([serviceId])
  @@index([professionalId])
}

// ─── Capability Factura + borde del Plugin ARCA (ADR-020 §6.a, ADR-022) ───
// El modelo Factura de ADR-003 "nace con el Plugin ARCA": acá es donde nace.
// Alcance mínimo a propósito (ADR-020: no materializar de forma especulativa):
// guarda lo necesario para pedir el CAE y registrar el resultado fiscal.
// El CÁLCULO de IVA vive en el Core, no en el plugin (ADR-006): los montos se
// guardan ya calculados. `docNro` es texto (un CUIT de 11 dígitos no entra en
// un Int de 32 bits). Los campos de CAE son nulos hasta que ARCA autoriza.

enum InvoiceStatus {
  PENDING // creada; esperando autorización de ARCA
  AUTHORIZED // CAE obtenido
  REJECTED // ARCA la rechazó
}

model Invoice {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  // Identidad fiscal del comprobante (códigos de catálogo de ARCA).
  puntoVenta      Int
  tipoComprobante Int? // TipoComprobante de WSFEv1 (1=A, 6=B, 11=C). Nulo hasta
  //                      la autorización: lo deriva el plugin ARCA (ADR-022) y
  //                      lo escribe `registerFiscalDocument`.
  concepto Int // 1=Productos, 2=Servicios, 3=ambos
  docTipo  Int // 80=CUIT, 96=DNI, 99=Consumidor Final
  docNro   String
  fecha    String // AAAAMMDD

  // Montos calculados por el Core (ADR-006).
  neto  Float
  iva   Float
  total Float

  status InvoiceStatus @default(PENDING)

  // Resultado fiscal de ARCA — nulo hasta autorización.
  cae            String?
  caeVencimiento String? // AAAAMMDD
  numero         Int? // correlativo asignado por ARCA
  rechazoMotivo  String? // detalle si status=REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
}

// Outbox transaccional (ADR-002): el Core escribe el evento de dominio en la
// MISMA transacción que la operación de negocio; un worker lo lee y lo despacha
// al plugin. Garantiza que una factura creada siempre termine enviada a ARCA
// aunque el proceso muera entre "guardar" y "despachar". `processedAt` nulo =
// pendiente. Genérico (no solo ARCA): `type` discrimina el evento.
model OutboxEvent {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  type    String // ej. "InvoiceCreated"
  payload Json

  processedAt DateTime? // null = pendiente de despacho
  attempts    Int       @default(0)
  lastError   String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([processedAt])
}
