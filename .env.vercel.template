# ============================================================================
# Plantilla de variables de entorno para VERCEL (proyecto erp-ch, Hobby)
# ----------------------------------------------------------------------------
# SOLO NOMBRES + para qué sirve cada una. NO tiene valores secretos.
# Uso: completá los valores y pegá/importá en Vercel → Settings → Environment
# Variables (ambiente Production). Los valores de DB/secretos son los MISMOS que
# ya usás en prod (Neon) — no inventes.
#
# Regla: NO commitees este archivo con valores. Los secretos van SOLO en Vercel.
# ============================================================================

# ── OBLIGATORIAS (sin estas la app no arranca sana) ─────────────────────────

# Conexión principal a Neon con el rol de la app (app_rls cuando RLS está ON).
DATABASE_URL=

# Conexión a Neon con el rol OWNER (neondb_owner) para el control-plane /operador
# (cross-tenant). Si falta, cae a DATABASE_URL (app_rls) y el operador queda
# bloqueado por RLS. Setear SIEMPRE en prod multi-tenant.
OPERATOR_DATABASE_URL=

# Secreto HMAC que firma la cookie de sesión del panel del tenant (/admin).
AUTH_SECRET=

# Secreto HMAC de la cookie del operador (/operador) — llavero SEPARADO del tenant.
OPERATOR_SECRET=

# Contraseña de la consola de operador (/operador/login). Obligatoria en prod.
# NOTA: el código usa OPERATOR_PASSWORD, NO "ADMIN_PASSWORD" (esa no la lee nadie).
OPERATOR_PASSWORD=

# Activa el candado RLS de Postgres (aislamiento por fila). Poner exactamente: on
RLS_ENFORCEMENT=on

# ── RUTEO POR TENANT ────────────────────────────────────────────────────────

# Mapa EXACTO hostname → subdomain del tenant, para URLs .vercel.app GRATIS
# (sin dominio propio). Formato: "host1=sub1;host2=sub2". Se resuelve ANTES que
# el subdominio de APP_BASE_DOMAIN. Valor para este deploy:
#   TENANT_HOST_MAP=chestetica-erp.vercel.app=chestetica;magra-erp.vercel.app=magra;shinevelas-erp.vercel.app=shinevelas;adosmanos-erp.vercel.app=adosmanos
TENANT_HOST_MAP=

# Dominio base para routing por SUBDOMINIO (dominio propio: <sub>.APP_BASE_DOMAIN).
# ⚠️ En el deploy .vercel.app SIN dominio propio: DEJAR VACÍO / NO SETEAR.
#    (Poner "vercel.app" acá rompería: trataría "chestetica-erp" como subdominio.)
# APP_BASE_DOMAIN=

# ── RECOMENDADA ─────────────────────────────────────────────────────────────

# Protege /api/cron/reminders. Vercel Cron inyecta el Bearer automáticamente
# cuando esta var existe. Sin ella el endpoint queda abierto (fail-open).
CRON_SECRET=

# ── OPCIONALES (encienden features; sin ellas la feature queda inerte) ───────

# Firma de webhooks de Mercado Pago (HMAC). Necesaria SOLO al activar cobros MP
# reales (con invoicing ON, sin ella el webhook responde 503 fail-closed).
MP_WEBHOOK_SECRET=

# Envío de emails (recordatorios/notificaciones) vía Resend. Sin key → modo simulado.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# API pública de ingesta de pedidos externos (WordPress/Woo). Una clave única, o
# la variante multi-tenant JSON {"<slug>":"<key>"} en EXTERNAL_ORDERS_API_KEYS.
EXTERNAL_ORDERS_API_KEY=
EXTERNAL_ORDERS_API_KEYS=

# Flag de facturación electrónica ARCA (off por default; requiere cert + homologación).
ARCA_INVOICING_ENABLED=

# ── NO SETEAR EN ESTE DEPLOY ────────────────────────────────────────────────
# FORCE_TENANT_SLUG → fijaría TODO el proyecto a un solo tenant (Opción A) y
#   rompería el multi-tenant por host/subdominio. Solo para un preview de 1 tenant.
# ADMIN_PASSWORD → legacy, el runtime NO la lee. No hace falta.
#
# ── LAS PROVEE VERCEL SOLA — NO cargar ──────────────────────────────────────
# VERCEL_GIT_COMMIT_SHA (commit del deploy, lo lee /api/health) · NODE_ENV=production
